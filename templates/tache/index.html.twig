<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>TaskManager</title>

    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            margin: 0;
            padding: 0;
        }

        .container {
            width: 500px;
            margin: 80px auto;
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
        }

        ul {
            list-style: none;
            padding: 0;
        }

        li {
            display: flex;
            justify-content: space-between;
            padding: 10px;
            margin-bottom: 10px;
            background: #f7f7f7;
            border-radius: 8px;
        }

        a {
            text-decoration: none;
            color: white;
            background: #e74c3c;
            padding: 5px 10px;
            border-radius: 6px;
        }

        a:hover {
            background: #c0392b;
        }

        .form {
            margin-top: 20px;
            display: flex;
            gap: 10px;
        }

        input {
            flex: 1;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        button {
            padding: 10px 15px;
            border: none;
            background: #2ecc71;
            color: white;
            border-radius: 6px;
            cursor: pointer;
        }

        button:hover {
            background: #27ae60;
        }
    </style>
</head>

<body>

<div class="container">

    <h1>📝 TaskManager</h1>

    <ul>
        {% for tache in taches %}
            <li>
                <span>{{ tache.titre }}</span>
                <a href="/delete/{{ tache.id }}">Suppr</a>
            </li>
        {% endfor %}
    </ul>

    <div class="form">
        {{ form_start(form) }}
            {{ form_widget(form.titre) }}
            <button type="submit">Ajouter</button>
        {{ form_end(form) }}
    </div>

</div>

</body>
</html>